<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- خلفية مطابقة لنفس ألوان الـ Splash Screen في Flutter -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#2A3446"
                android:centerColor="#354155"
                android:endColor="#929AAB"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
